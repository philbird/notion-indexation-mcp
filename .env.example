# Required: Notion integration token (create at https://www.notion.so/my-integrations)
NOTION_TOKEN=ntn_...

# ChromaDB server URL (default: http://localhost:8000)
CHROMA_URL=http://localhost:8000

# ChromaDB collection name (default: notion-index)
CHROMA_COLLECTION=notion-index

# Ollama server URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Ollama embedding model (default: nomic-embed-text)
OLLAMA_MODEL=nomic-embed-text

# Sync interval in minutes (default: 30)
SYNC_INTERVAL_MINUTES=30

# Path to sync state file (default: ./sync-state.json)
SYNC_STATE_PATH=./sync-state.json

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
